{
  "name": "@memrosetta/obsidian",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "memrosetta-obsidian": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@memrosetta/core": "workspace:*",
    "@memrosetta/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
