{
  "name": "@memrosetta/sync-server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/standalone.js",
    "start:dev": "tsx src/standalone.ts",
    "build": "tsup src/index.ts src/standalone.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@memrosetta/types": "workspace:*",
    "@memrosetta/postgres": "workspace:*",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
