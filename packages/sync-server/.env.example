# MemRosetta Sync Server Configuration
# Copy to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8081
CORS_ORIGINS=http://localhost:3000

# Authentication (comma-separated API keys)
MEMROSETTA_API_KEYS=your-api-key-here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/memrosetta_sync
PG_SSL_REJECT_UNAUTHORIZED=false
PG_POOL_SIZE=10
