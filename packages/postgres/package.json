{
  "name": "@memrosetta/postgres",
  "version": "0.1.0",
  "type": "module",
  "description": "PostgreSQL storage adapter for MemRosetta sync server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "migrations", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "echo 'No tests yet — integration tests require a PostgreSQL instance.'",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@memrosetta/types": "workspace:*",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
