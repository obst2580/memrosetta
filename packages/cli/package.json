{
  "name": "@memrosetta/cli",
  "version": "0.12.2",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "memrosetta": "./dist/index.js",
    "memrosetta-on-stop": "./dist/hooks/on-stop.js",
    "memrosetta-on-prompt": "./dist/hooks/on-prompt.js",
    "memrosetta-enforce-claude-code": "./dist/hooks/enforce-claude-code.js",
    "memrosetta-enforce-codex": "./dist/hooks/enforce-codex.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/hooks/on-stop.ts src/hooks/on-prompt.ts src/hooks/enforce-claude-code.ts src/hooks/enforce-codex.ts --format esm --external better-sqlite3 --external @memrosetta/core --external @memrosetta/sync-client --external @memrosetta/types --external @memrosetta/llm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@memrosetta/core": "workspace:*",
    "@memrosetta/sync-client": "workspace:*",
    "@memrosetta/types": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "optionalDependencies": {
    "@memrosetta/llm": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
