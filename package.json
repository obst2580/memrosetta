{
  "name": "memrosetta",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @memrosetta/types run build && pnpm --filter @memrosetta/embeddings run build && pnpm --filter @memrosetta/core run build && pnpm -r run build",
    "test": "pnpm run build && pnpm -r run test",
    "test:only": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "bench": "pnpm --filter benchmarks run bench",
    "bench:phase1": "pnpm --filter benchmarks run bench:phase1",
    "bench:mock": "pnpm --filter benchmarks run bench:mock",
    "bench:sqlite": "pnpm --filter benchmarks run bench:sqlite",
    "bench:hybrid": "pnpm --filter benchmarks run bench:hybrid",
    "bench:fact": "pnpm --filter benchmarks run bench -- --converter fact",
    "dev": "pnpm --filter @memrosetta/api run dev",
    "start": "pnpm --filter @memrosetta/api run start",
    "memrosetta": "pnpm --filter @memrosetta/cli run start --",
    "mcp": "pnpm --filter @memrosetta/mcp run start",
    "obsidian": "pnpm --filter @memrosetta/obsidian run start --"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
